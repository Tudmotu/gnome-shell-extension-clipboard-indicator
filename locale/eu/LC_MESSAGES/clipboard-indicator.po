msgid "This operation cannot be undone."
msgstr "Ezin da eragiketa hau desegin."

#: extension.js:849 prefs.js:177
msgid "Delete"
msgstr "Ezabatu"

#: extension.js:849 extension.js:860 extension.js:1040
msgid "Cancel"
msgstr "Utzi"

#: extension.js:856
msgid "Clear all?"
msgstr "Guztia garbitu?"

#: extension.js:857
msgid "Are you sure you want to delete all clipboard items?"
msgstr "Ziur arbeleko elementu guztiak kendu nahi dituzula?"

#: extension.js:860
msgid "Clear"
msgstr "Garbitu"

#: extension.js:876
#, fuzzy
msgid "Clipboard history cleared automatically"
msgstr "Arbelaren historia automatikoki garbitu da"

#: extension.js:877
msgid "Clipboard history cleared"
msgstr "Arbelaren historia garbitu da"

#: extension.js:1039
msgid "Copied to clipboard"
msgstr "Arbelera kopiatu da"

#: extension.js:1756
msgid "Enter tag…"
msgstr "Idatzi etiketa…"

#: extension.js:1765 extension.js:1857
msgid "Discard"
msgstr "Baztertu"

#: extension.js:1774 extension.js:1866
msgid "Save"
msgstr "Gorde"

#: prefs.js:15 prefs.js:261
msgid "UI"
msgstr "Erabiltzaile interfazea"

#: prefs.js:16 prefs.js:262
msgid "Behavior"
msgstr "Portaera"

#: prefs.js:17 prefs.js:268
msgid "Search"
msgstr "Bilaketa"

#: prefs.js:18 prefs.js:264
msgid "Limits"
msgstr "Mugak"

#: prefs.js:19 prefs.js:263
msgid "Exclusion"
msgstr "Salbuespena"

#: prefs.js:20 prefs.js:265
msgid "Topbar"
msgstr "Goiko barra"

#: prefs.js:21 prefs.js:266
msgid "Notifications"
msgstr "Jakinarazpenak"

#: prefs.js:22 prefs.js:267
msgid "Shortcuts"
msgstr "Laster-teklak"

#: prefs.js:40
msgid "History Size"
msgstr "Historiaren tamaina"

#: prefs.js:41
msgid "Maximum number of entries to keep in clipboard history"
msgstr "Arbelaren historian mantendu beharreko gehienezko sarrera kopurua"

#: prefs.js:50
msgid "Preview Size (characters)"
msgstr "Aurrebistaren tamaina (karaktereak)"

#: prefs.js:51
msgid "Number of characters shown per entry in the history menu"
msgstr ""
"Historia menuko sarrera bakoitzeko erakutsi beharreko karaktere kopurua"

#: prefs.js:60
msgid "Max cache file size (MB)"
msgstr "Cache fitxategiaren gehienezko tamaina (MB)"

#: prefs.js:61
msgid "Maximum disk space used for caching clipboard data"
msgstr "Arbeleko datuak cacheratzeko erabilitako diskoko gehienezko lekua"

#: prefs.js:70
msgid "Number of characters in top bar"
msgstr "Goiko barrako karaktere kopurua"

#: prefs.js:71
msgid "Length of the clipboard content preview shown in the panel"
msgstr "Panelean erakutsitako arbeleko edukien aurrebistaren luzera"

#: prefs.js:80
msgid "What to show in top bar"
msgstr "Zer erakutsi goiko barran"

#: prefs.js:85
msgid "Remove down arrow in top bar"
msgstr "Kendu beheranzko gezia goiko barran"

#: prefs.js:86
msgid "Hide the dropdown arrow next to the clipboard indicator"
msgstr "Ezkutatu arbelaren adierazlearen alboan erakusten den gezia"

#: prefs.js:90
msgid "Blink icon on copy"
msgstr "Keinatu ikonoa kopiatzean"

#: prefs.js:91
msgid "Briefly flash the indicator icon when something is copied"
msgstr "Zerbait kopiatzen denean, keinatu une labur batez ikono adierazlea"

#: prefs.js:95
msgid "Cache only pinned items"
msgstr "Ainguratutako sarrerak soilik cacheratu"

#: prefs.js:96
msgid "Only save pinned (favorite) entries to disk"
msgstr "Ainguratutako (gogoko) sarrerak soilik gorde diskoan"

#: prefs.js:100
msgid "Show notification on copy"
msgstr "Erakutsi jakinarazpena kopiatzean"

#: prefs.js:101
msgid "Display a notification each time text is copied"
msgstr "Erakutsi jakinarazpena eduki bat kopiatzen den aldiro"

#: prefs.js:105
msgid "Show notification on cycle"
msgstr "Erakutsi jakinarazpena nabigatzean"

#: prefs.js:106
msgid "Display a notification when cycling through entries with shortcuts"
msgstr "Erakutsi jakinarazpena sarreren artean laster-tekla bidez nabigatzean"

#: prefs.js:110
msgid "Show notification on Clear History"
msgstr "Erakutsi jakinarazpena historia garbitzerakoan"

#: prefs.js:111
msgid "Display a notification when clipboard history is cleared"
msgstr "Erakutsi jakinarazpena arbeleko historia garbitzen denean"

#: prefs.js:115
msgid "Prompt for confirmation on Clear History"
msgstr "Eskatu berrespena historia garbitzerakoan"

#: prefs.js:116
msgid "Ask before deleting all clipboard entries"
msgstr "Galdetu arbeleko sarrera guztiak ezabatu aurretik"

#: prefs.js:120
msgid "Prompt before deleting pinned item"
msgstr ""

#: prefs.js:121
msgid "Ask for confirmation before deleting a pinned item"
msgstr ""

#: prefs.js:125
msgid "Remove whitespace around text"
msgstr "Kendu testuaren inguruko zuriuneak"

#: prefs.js:126
msgid "Strip leading and trailing whitespace from text entries on copy"
msgstr ""
"Kendu hasierako eta amaierako zuriuneak testuzko sarrera bat kopiatzen denean"

#: prefs.js:130
msgid "Move item to the top after selection"
msgstr "Eraman elementua goraino hautatu ostean"

#: prefs.js:131
msgid "When selecting an entry, bring it to the top of the history"
msgstr "Sarrera bat hautatzean, eraman hau historian goraino"

#: prefs.js:135
msgid "Keep selected entry after Clear History"
msgstr "Mantendu hautatutako sarrera historia garbitzean"

#: prefs.js:136
msgid ""
"The currently active clipboard entry will not be removed when clearing "
"history"
msgstr ""
"Unean aukeratuta dagoen arbeleko sarrera ez da ezabatuko historia garbitzen "
"denean"

#: prefs.js:140
msgid "Place the pinned section on the bottom"
msgstr "Kokatu ainguratutakoen atala behealdean"

#: prefs.js:141
msgid "Move the pinned section to the bottom of the menu. Requires re-login"
msgstr ""
"Kokatu ainguratutakoen atala menuaren behealdean. Saioa berriro hasi beharra "
"dago."

#: prefs.js:145
msgid "Show Search Bar"
msgstr "Erakutsi bilaketa-barra"

#: prefs.js:146
msgid "Display a search field at the top of the clipboard menu"
msgstr "Erakutsi bilaketa-eremua arbelaren menuko goialdean"

#: prefs.js:149
msgid "Show Private Mode"
msgstr "Erakutsi 'Modu pribatua'"

#: prefs.js:150
msgid "Display the private mode toggle in the clipboard menu"
msgstr "Erakutsi modu pribatua gaitu/ezgaitzeko botoia arbelaren menuan"

#: prefs.js:153
msgid "Show Settings Button"
msgstr "Erakutsi 'Ezarpenak' botoia"

#: prefs.js:154
msgid "Display a shortcut to these settings in the clipboard menu"
msgstr "Erakutsi ezarpen hauetarako lasterbidea arbelaren menuan"

#: prefs.js:157
msgid "Show Clear History Button"
msgstr "Erakutsi 'Garbitu historia' botoia"

#: prefs.js:158
msgid "Display the clear history button in the clipboard menu"
msgstr "Erakutsi historia garbitzeko botoia arbelaren menuan"

#: prefs.js:162
msgid "Clear clipboard history on system reboot"
msgstr "Garbitu arbelaren historia sistema berrabiaraztean"

#: prefs.js:163
msgid "Delete all cached clipboard entries when the system starts"
msgstr ""
"Ezabatu cacheratutako arbeleko sarrera guztiak sistema abiarazten denean"

#: prefs.js:167
msgid "Paste on select"
msgstr "Itsatsi hautatzean"

#: prefs.js:168
msgid "Automatically paste the entry into the active window when selected"
msgstr ""
"Sarrera bat hautatzean, itsatsi automatikoki sarreraren edukia aktibo dagoen "
"leihoan"

#: prefs.js:172
msgid "Open menu at cursor"
msgstr "Ireki menua kurtsorean"

#: prefs.js:173
msgid "When using the keyboard shortcut, open the menu at the cursor position"
msgstr "Teklatuko lasterbidea erabiltzean, ireki menua kurtsorearen kokapenean"

#: prefs.js:178
msgid "Show the delete button on each item"
msgstr "Erakutsi ezabatzeko botoia sarrera bakoitzean"

#: prefs.js:182
msgid "Tag"
msgstr "Etiketak"

#: prefs.js:183
msgid "Show the tag button on each item"
msgstr "Erakutsi etiketen botoia sarrera bakoitzean"

#: prefs.js:188
msgid "Show the paste button on each item"
msgstr "Erakutsi itsasteko botoia sarrera bakoitzean"

#: prefs.js:192
msgid "Pin"
msgstr "Ainguratu"

#: prefs.js:193
msgid "Show the pin/favorite button on each item"
msgstr "Erakutsi ainguratzeko botoia sarrera bakoitzean"

#: prefs.js:198
msgid "Show the edit button on each text item"
msgstr "Erakutsi editatzeko botoia testuzko sarrera bakoitzean"

#: prefs.js:202
msgid "Preview"
msgstr "Aurrebista"

#: prefs.js:203
msgid "Show the preview button on each image item"
msgstr "Erakutsi aurreikusteko botoia irudizko sarrera bakoitzean"

#: prefs.js:207
msgid "Cache images"
msgstr "Cacheratu irudiak"

#: prefs.js:208
msgid "Save copied images to clipboard history"
msgstr "Gorde kopiatutako irudiak arbelaren historian"

#: prefs.js:213
msgid "Excluded Apps"
msgstr "Salbuetsitako aplikazioak"

#: prefs.js:214
msgid "Content copied will not be saved while these apps are in focus"
msgstr "Aplikazio hauek fokua dutenean kopiatutako edukia ez da gordeko"

#: prefs.js:225
msgid "Case-sensitive"
msgstr "Bereizi maiuskulak/minuskulak"

#: prefs.js:226
msgid "Match uppercase and lowercase letters exactly when searching"
msgstr "Bilatzerakoan, behartu maiuskulak eta minuskulak bat etortzea"

#: prefs.js:230
msgid "Regular expressions"
msgstr "Adierazpen erregularrak"

#: prefs.js:231
msgid "Allow regular expressions to filter clipboard entries"
msgstr "Onartu adierazpen erregularrak arbeleko sarrerak iragazteko"

#: prefs.js:244
msgid "Clear clipboard history on interval"
msgstr "Garbitu arbelaren historia tarteka"

#: prefs.js:245
msgid "Automatically clear clipboard history at a recurring interval"
msgstr "Garbitu arbelaren historia automatikoki tartean behin"

#: prefs.js:249
msgid "History clear interval (in minutes)"
msgstr "Historia ezabatzeko bitartea (minututan)"

#: prefs.js:269
msgid "Item Actions"
msgstr "Sarreretako ekintzak"

#: prefs.js:361
msgid "Icon"
msgstr "Ikonoa"

#: prefs.js:362
msgid "Clipboard Content"
msgstr "Arbelaren edukia"

#: prefs.js:363
msgid "Both"
msgstr "Biak"

#: prefs.js:364
msgid "Neither"
msgstr "Bat ere ez"

#: prefs.js:375
msgid "Toggle the menu"
msgstr "Erakutsi/ezkutatu menua"

#: prefs.js:377
msgid "Previous entry"
msgstr "Aurreko sarrera"

#: prefs.js:378
msgid "Next entry"
msgstr "Hurrengo sarrera"

#: prefs.js:383
msgid "Enable shortcuts"
msgstr "Gaitu laster-teklak"

#: prefs.js:408
msgid "Disabled"
msgstr "Ezgaituta"

#: prefs.js:417
msgid "Enter shortcut"
msgstr "Sartu laster-tekla"

#: prefs.js:504
msgid "Window class name, e.g. \"KeePassXC\""
msgstr "Leihoaren klase-izena, adb. \"KeePassXC\""

#: prefs.js:516
msgid "Choose from installed applications"
msgstr "Aukeratu instalatutako aplikazioetatik"

#: prefs.js:533
msgid "Search applications..."
msgstr "Bilatu aplikazioak..."

