msgid "Private mode"
msgstr "Modu pribatua"

#: extension.js:330 prefs.js:376
msgid "Clear history"
msgstr "Garbitu historia"

#: extension.js:355
msgid "Reset Timer"
msgstr "Berrezarri tenporizadorea"

#: extension.js:376
msgid "Settings"
msgstr "Ezarpenak"

#: extension.js:398
msgid "Clipboard is empty"
msgstr "Arbela hutsik dago"

#: extension.js:706
msgid "Preview Image"
msgstr "Irudiaren aurrebista"

#: extension.js:724 prefs.js:197
msgid "Edit"
msgstr "Editatu"

#: extension.js:762 prefs.js:187
msgid "Paste"
msgstr "Itsatsi"

