#: extension.js:144
msgid "Text will be here"
msgstr "Zde bude text"

#: extension.js:240
msgid "Type here to search..."
msgstr "Vyhledávejte psaním…"

#: extension.js:315 prefs.js:367
msgid "Private mode"
msgstr "Soukromý režim"

#: extension.js:329 prefs.js:369
msgid "Clear history"
msgstr "Smazat historii"

#: extension.js:354
msgid "Reset Timer"
msgstr "Vynulovat časovač"

#: extension.js:375
msgid "Settings"
msgstr "Nastavení"

#: extension.js:397
msgid "Clipboard is empty"
msgstr "Schránka je prázdná"

#: extension.js:691
msgid "Preview Image"
msgstr "Náhled obrázku"

#: extension.js:710 prefs.js:192
msgid "Edit"
msgstr "Editovat"

#: extension.js:750 prefs.js:182
msgid "Paste"
msgstr "Vložit"

#: extension.js:832
msgid "Clear all?"
msgstr "Vyčistit vše?"

#: extension.js:833
msgid "Are you sure you want to delete all clipboard items?"
msgstr "Opravdu chcete smazat všechny položky schránky?"

#: extension.js:834
msgid "This operation cannot be undone."
msgstr "Tato operace nejde vrátit."

#: extension.js:836
msgid "Clear"
msgstr "Vyčistit"

#: extension.js:836 extension.js:1016
msgid "Cancel"
msgstr "Storno"

#: extension.js:852
msgid "Clipboard history cleared automatically"
msgstr "Historie schránky automaticky vyčištěna"

#: extension.js:853
msgid "Clipboard history cleared"
msgstr "Historie schránky vyčištěna"

#: extension.js:1015
msgid "Copied to clipboard"
msgstr "Zkopírováno do schránky"

#: extension.js:1730
msgid "Enter tag…"
msgstr "Vlož značku..."

#: extension.js:1739 extension.js:1831
msgid "Discard"
msgstr "Zrušit"

#: extension.js:1748 extension.js:1840
msgid "Save"
msgstr "Uložit"

#: prefs.js:15 prefs.js:256
msgid "UI"
msgstr "Uživatelské rozhraní"

#: prefs.js:16 prefs.js:257
msgid "Behavior"
msgstr "Chování"

#: prefs.js:17 prefs.js:263
msgid "Search"
msgstr "Hledání"

#: prefs.js:18 prefs.js:259
msgid "Limits"
msgstr "Limity"

#: prefs.js:19 prefs.js:258
msgid "Exclusion"
msgstr "Vyloučení"

#: prefs.js:20 prefs.js:260
msgid "Topbar"
msgstr "Horní lišta"

#: prefs.js:21 prefs.js:261
msgid "Notifications"
msgstr "Oznámení"

#: prefs.js:22 prefs.js:262
msgid "Shortcuts"
msgstr "Zkratky"

#: prefs.js:40
msgid "History Size"
msgstr "Hloubka historie"

#: prefs.js:41
msgid "Maximum number of entries to keep in clipboard history"
msgstr "Maximální počet položek k uchování v historii schránky"

#: prefs.js:50
msgid "Preview Size (characters)"
msgstr "Délka náhledu (znaky)"

#: prefs.js:51
msgid "Number of characters shown per entry in the history menu"
msgstr "Počet znaků zobrazených u každého záznamu v nabídce historie"

#: prefs.js:60
msgid "Max cache file size (MB)"
msgstr "Maximální velikost souboru mezipaměti (MB)"

#: prefs.js:61
msgid "Maximum disk space used for caching clipboard data"
msgstr ""
"Maximální velikost diskového prostoru pro ukládání dat ze schránky do "
"mezipaměti"

#: prefs.js:70
msgid "Number of characters in top bar"
msgstr "Počet znaků v horní liště"

#: prefs.js:71
msgid "Length of the clipboard content preview shown in the panel"
msgstr "Délka náhledu obsahu schránky zobrazeného v panelu"

#: prefs.js:80
msgid "What to show in top bar"
msgstr "Co zobrazovat v horní liště"

#: prefs.js:85
msgid "Remove down arrow in top bar"
msgstr "Nezobrazovat šipku dolů v horní liště"

#: prefs.js:86
msgid "Hide the dropdown arrow next to the clipboard indicator"
msgstr "Skrýt šipku rozbalovacího seznamu vedle indikátoru schránky"

#: prefs.js:90
msgid "Blink icon on copy"
msgstr "Při kopírování blikne ikona"

#: prefs.js:91
msgid "Briefly flash the indicator icon when something is copied"
msgstr "Při kopírování krátce zabliká ikona indikátoru"

#: prefs.js:95
msgid "Cache only pinned items"
msgstr "Ukládat do mezipaměti pouze připnuté položky"

#: prefs.js:96
msgid "Only save pinned (favorite) entries to disk"
msgstr "Na disk ukládat pouze připnuté (oblíbené) položky"

#: prefs.js:100
msgid "Show notification on copy"
msgstr "Při zkopírování zobrazit oznámení"

#: prefs.js:101
msgid "Display a notification each time text is copied"
msgstr "Zobrazit upozornění při každém zkopírování textu"

#: prefs.js:105
msgid "Show notification on cycle"
msgstr "Zobraz oznámení cyklicky"

#: prefs.js:106
msgid "Display a notification when cycling through entries with shortcuts"
msgstr "Zobrazit upozornění při procházení položek pomocí klávesových zkratek"

#: prefs.js:110
msgid "Show notification on Clear History"
msgstr "Zobraz oznámení při mazání historie"

#: prefs.js:111
msgid "Display a notification when clipboard history is cleared"
msgstr "Zobrazit upozornění při vymazání historie schránky"

#: prefs.js:115
msgid "Prompt for confirmation on Clear History"
msgstr "Výzva k potvrzení vymazání historie"

#: prefs.js:116
msgid "Ask before deleting all clipboard entries"
msgstr "Před smazáním všech položek ze schránky se zeptej"

#: prefs.js:120
msgid "Remove whitespace around text"
msgstr "Odebrat prázdné znaky kolem textu"

#: prefs.js:121
msgid "Strip leading and trailing whitespace from text entries on copy"
msgstr "Při kopírování odstranit mezery na začátku a na konci textu"

#: prefs.js:125
msgid "Move item to the top after selection"
msgstr "Po výběru posunout položku na začátek seznamu"

#: prefs.js:126
msgid "When selecting an entry, bring it to the top of the history"
msgstr "Při výběru položky tuto přesune na začátek historie"

#: prefs.js:130
msgid "Keep selected entry after Clear History"
msgstr "Ponechej položku po Vyčištění historie"

#: prefs.js:131
msgid ""
"The currently active clipboard entry will not be removed when clearing "
"history"
msgstr "Aktuální položka ve schránce nebude při vymazání historie odstraněna"

#: prefs.js:135
msgid "Place the pinned section on the bottom"
msgstr "Umísti připnutou část dolů"

#: prefs.js:136
msgid "Move the pinned section to the bottom of the menu. Requires re-login"
msgstr "Přesuňte připnutou část na konec nabídky. Je nutno se znovu přihlásit"

#: prefs.js:140
msgid "Show Search Bar"
msgstr "Zobraz vyhledávací lištu"

#: prefs.js:141
msgid "Display a search field at the top of the clipboard menu"
msgstr "Zobraz vyhledávací pole v horní části nabídky schránky"

#: prefs.js:144
msgid "Show Private Mode"
msgstr "Zobraz soukromý režim"

#: prefs.js:145
msgid "Display the private mode toggle in the clipboard menu"
msgstr "Zobraz přepínač soukromého režimu v nabídce schránky"

#: prefs.js:148
msgid "Show Settings Button"
msgstr "Zobraz tlačítko Nastavení"

#: prefs.js:149
msgid "Display a shortcut to these settings in the clipboard menu"
msgstr "Zobraz zástupce těchto nastavení v nabídce schránky"

#: prefs.js:152
msgid "Show Clear History Button"
msgstr "Zobraz tlačítko Smazat historii"

#: prefs.js:153
msgid "Display the clear history button in the clipboard menu"
msgstr "Zobraz tlačítko pro vymazání historie v nabídce schránky"

#: prefs.js:157
msgid "Clear clipboard history on system reboot"
msgstr "Vyčisti historii schránky při restartu"

#: prefs.js:158
msgid "Delete all cached clipboard entries when the system starts"
msgstr "Při spuštění systému smaž všechny položky v mezipaměti schránky"

#: prefs.js:162
msgid "Paste on select"
msgstr "Vložit do výběru"

#: prefs.js:163
msgid "Automatically paste the entry into the active window when selected"
msgstr "Po výběru položku automaticky vložit do aktivního okna"

#: prefs.js:167
msgid "Open menu at cursor"
msgstr "Otevři nabídku na pozici kurzoru"

#: prefs.js:168
msgid "When using the keyboard shortcut, open the menu at the cursor position"
msgstr ""
"Při použití klávesové zkratky otevřete nabídku v místě, kde se nachází "
"kurzor"

#: prefs.js:172
msgid "Delete"
msgstr "Smazat"

#: prefs.js:173
msgid "Show the delete button on each item"
msgstr "Zobrazit tlačítko Smazat u každé položky"

#: prefs.js:177
msgid "Tag"
msgstr "Značka"

#: prefs.js:178
msgid "Show the tag button on each item"
msgstr "Zobrazit tlačítko značky u každé položky"

#: prefs.js:183
msgid "Show the paste button on each item"
msgstr "Zobraz tlačítko Vložit u každé položky"

#: prefs.js:187
msgid "Pin"
msgstr "Připnout"

#: prefs.js:188
msgid "Show the pin/favorite button on each item"
msgstr "Zobrazit tlačítko značka/favorit u každé položky"

#: prefs.js:193
msgid "Show the edit button on each text item"
msgstr "Zobrazit tlačítko pro úpravy u každé textové položky"

#: prefs.js:197
msgid "Preview"
msgstr "Náhled"

#: prefs.js:198
msgid "Show the preview button on each image item"
msgstr "Zobrazit tlačítko náhledu u každého obrázku"

#: prefs.js:202
msgid "Cache images"
msgstr "Obrázky do mezipaměti"

#: prefs.js:203
msgid "Save copied images to clipboard history"
msgstr "Uložit zkopírované obrázky do historie schránky"

#: prefs.js:208
msgid "Excluded Apps"
msgstr "Vyloučené aplikace"

#: prefs.js:209
msgid "Content copied will not be saved while these apps are in focus"
msgstr "Obsah nebude uložen, jsou-li tyto aplikace aktivní"

#: prefs.js:220
msgid "Case-sensitive"
msgstr "Rozlišuj velká a malá písmena"

#: prefs.js:221
msgid "Match uppercase and lowercase letters exactly when searching"
msgstr "Při vyhledávání striktně porovnávejte velká a malá písmena"

#: prefs.js:225
msgid "Regular expressions"
msgstr "Regulární výrazy"

#: prefs.js:226
msgid "Allow regular expressions to filter clipboard entries"
msgstr "Povolit filtrování položek ve schránce pomocí regulárních výrazů"

#: prefs.js:239
msgid "Clear clipboard history on interval"
msgstr "Vyčisti historii schránky v intervalu"

#: prefs.js:240
msgid "Automatically clear clipboard history at a recurring interval"
msgstr "Vyčisti historii schránky v pravidelném intervalu"

#: prefs.js:244
msgid "History clear interval (in minutes)"
msgstr "Interval čištění historie (minuty)"

#: prefs.js:264
msgid "Item Actions"
msgstr "Akce s položkami"

#: prefs.js:354
msgid "Icon"
msgstr "Ikona"

#: prefs.js:355
msgid "Clipboard Content"
msgstr "Obsah schránky"

#: prefs.js:356
msgid "Both"
msgstr "Obojí"

#: prefs.js:357
msgid "Neither"
msgstr "Nic"

#: prefs.js:368
msgid "Toggle the menu"
msgstr "Přepnout nabídku"

#: prefs.js:370
msgid "Previous entry"
msgstr "Předchozí položka"

#: prefs.js:371
msgid "Next entry"
msgstr "Následující položka"

#: prefs.js:376
msgid "Enable shortcuts"
msgstr "Povol klávesové zkratky"

#: prefs.js:401
msgid "Disabled"
msgstr "Zakázáno"

#: prefs.js:410
msgid "Enter shortcut"
msgstr "Vlož klávesovou zkratku"

#: prefs.js:497
msgid "Window class name, e.g. \"KeePassXC\""
msgstr "Název třídy okna, např. \"KeePassXC\""

#: prefs.js:509
msgid "Choose from installed applications"
msgstr "Vyber z instalovaných aplikací"

#: prefs.js:526
msgid "Search applications..."
msgstr "Hledej aplikace..."

#~ msgid "Adds a paste button to each entry that lets you paste it directly"
#~ msgstr "Přidej tlačítko Vložit ke každé položce k přímému vložení"

#~ msgid "Requires restarting the extension"
#~ msgstr "Vyžaduje restart rozšíření"
