#: extension.js:1039
msgid "Copied to clipboard"
msgstr "Copiado para a área de transferência"

#: extension.js:1756
msgid "Enter tag…"
msgstr "Entrar marcador..."

#: extension.js:1765 extension.js:1857
msgid "Discard"
msgstr "Descartar"

