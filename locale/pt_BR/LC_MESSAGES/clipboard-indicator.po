#: prefs.js:15 prefs.js:261
msgid "UI"
msgstr "IU"

#: prefs.js:16 prefs.js:262
msgid "Behavior"
msgstr "Comportamento"

#: prefs.js:17 prefs.js:268
msgid "Search"
msgstr "Buscar"

#: prefs.js:18 prefs.js:264
msgid "Limits"
msgstr "Limites"

#: prefs.js:19 prefs.js:263
msgid "Exclusion"
msgstr "Exclusão"

#: prefs.js:20 prefs.js:265
msgid "Topbar"
msgstr "Barra superior"

#: prefs.js:21 prefs.js:266
msgid "Notifications"
msgstr "Notificações"

#: prefs.js:22 prefs.js:267
msgid "Shortcuts"
msgstr "Atalhos"

#: prefs.js:40
msgid "History Size"
msgstr "Tamanho do histórico"

#: prefs.js:41
msgid "Maximum number of entries to keep in clipboard history"
msgstr ""
"Número máximo de registros para manter no histórico da área de transferência"

#: prefs.js:50
msgid "Preview Size (characters)"
msgstr "Tamanho da visualização (caracteres)"

#: prefs.js:51
msgid "Number of characters shown per entry in the history menu"
msgstr "Número de caracteres mostrados por registro no menu de histórico"

#: prefs.js:60
msgid "Max cache file size (MB)"
msgstr "Tamanho máximo do arquivo de cache (MB)"

#: prefs.js:61
msgid "Maximum disk space used for caching clipboard data"
msgstr "Espaço em disco máximo para guardar dados da área de transferência"

#: prefs.js:70
msgid "Number of characters in top bar"
msgstr "Número de caracteres na barra superior"

#: prefs.js:71
msgid "Length of the clipboard content preview shown in the panel"
msgstr ""
"Tamanho da visualização de conteúdo da área de transferência mostrada no "
"painel"

#: prefs.js:80
msgid "What to show in top bar"
msgstr "O que mostrar na barra superior"

#: prefs.js:85
msgid "Remove down arrow in top bar"
msgstr "Remover a seta para baixo da barra superior"

#: prefs.js:86
msgid "Hide the dropdown arrow next to the clipboard indicator"
msgstr ""
"Esconder a seta para baixo próxima ao indicador da área de transferência"

#: prefs.js:90
msgid "Blink icon on copy"
msgstr "Piscar ícone ao copiar"

#: prefs.js:91
msgid "Briefly flash the indicator icon when something is copied"
msgstr "Piscar momentaneamente o ícone de indicação quando algo for copiado"

#: prefs.js:95
msgid "Cache only pinned items"
msgstr "Manter cache apenas dos itens fixados"

#: prefs.js:96
msgid "Only save pinned (favorite) entries to disk"
msgstr "Apenas salvar registros fixados (favoritos) no disco"

#: prefs.js:100
msgid "Show notification on copy"
msgstr "Mostrar notificação ao copiar"

#: prefs.js:101
msgid "Display a notification each time text is copied"
msgstr "Mostrar uma notificação toda vez que texto é copiado"

#: prefs.js:105
msgid "Show notification on cycle"
msgstr "Mostrar notificação ao alternar"

#: prefs.js:106
msgid "Display a notification when cycling through entries with shortcuts"
msgstr "Mostrar uma notificação quando alternar entre registros com atalhos"

#: prefs.js:110
msgid "Show notification on Clear History"
msgstr "Mostrar confirmação ao limpar histórico"

#: prefs.js:111
msgid "Display a notification when clipboard history is cleared"
msgstr "Mostrar uma notificação ao limpar histórico da área de transferência"

#: prefs.js:115
msgid "Prompt for confirmation on Clear History"
msgstr "Mostrar confirmação ao limpar histórico"

#: prefs.js:116
msgid "Ask before deleting all clipboard entries"
msgstr "Perguntar antes de apagar todos os registros da área de transferência"

#: prefs.js:120
msgid "Prompt before deleting pinned item"
msgstr ""

#: prefs.js:121
msgid "Ask for confirmation before deleting a pinned item"
msgstr ""

#: prefs.js:125
msgid "Remove whitespace around text"
msgstr "Remover os espaços em branco ao redor do texto"

#: prefs.js:126
msgid "Strip leading and trailing whitespace from text entries on copy"
msgstr ""
"Remover espaço em brando do início e fim dos registros de textos ao copiar"

#: prefs.js:130
msgid "Move item to the top after selection"
msgstr "Mover o item para o topo após a seleção"

#: prefs.js:131
msgid "When selecting an entry, bring it to the top of the history"
msgstr "Ao selecionar um registro, traga-o para o topo do histórico"

#: prefs.js:135
msgid "Keep selected entry after Clear History"
msgstr "Manter a entrada selecionada após Limpar Histórico"

#: prefs.js:136
msgid ""
"The currently active clipboard entry will not be removed when clearing "
"history"
msgstr ""
"O registro atual da área de trabalho não será apagado ao limpar o histórico"

#: prefs.js:140
msgid "Place the pinned section on the bottom"
msgstr "Posicionar a seção fixada na parte inferior"

#: prefs.js:141
msgid "Move the pinned section to the bottom of the menu. Requires re-login"
msgstr ""
"Mova a seção fixada para a parte inferior do menu. Necessita autenticar "
"novamente"

#: prefs.js:145
msgid "Show Search Bar"
msgstr "Mostrar barra de busca"

#: prefs.js:146
msgid "Display a search field at the top of the clipboard menu"
msgstr "Mostra um campo de busca no topo do menu da área de transferência"

#: prefs.js:149
msgid "Show Private Mode"
msgstr "Mostrar modo privado"

#: prefs.js:150
msgid "Display the private mode toggle in the clipboard menu"
msgstr "Mostra alternador para modo privado no menu da área de transferência"

#: prefs.js:153
msgid "Show Settings Button"
msgstr "Mostrar botão de configurações"

#: prefs.js:154
msgid "Display a shortcut to these settings in the clipboard menu"
msgstr ""
"Mostra um atalho para essas configurações no menu da área de transferência"

#: prefs.js:157
msgid "Show Clear History Button"
msgstr "Mostrar botão limpar histórico da área de transferência"

#: prefs.js:158
msgid "Display the clear history button in the clipboard menu"
msgstr "Mostra o botão limpar histórico no menu da área de transferência"

#: prefs.js:162
msgid "Clear clipboard history on system reboot"
msgstr "Limpar histórico da área de transferência ao reiniciar"

#: prefs.js:163
msgid "Delete all cached clipboard entries when the system starts"
msgstr ""
"Apagar todos registros armazenados da área de transferência ao iniciar o "
"sistema"

#: prefs.js:167
msgid "Paste on select"
msgstr "Colar ao selecionar"

#: prefs.js:168
msgid "Automatically paste the entry into the active window when selected"
msgstr "Colar automaticamente o registro na janela ativa ao selecionar"

#: prefs.js:172
msgid "Open menu at cursor"
msgstr "Abrir menu no ponteiro"

#: prefs.js:173
msgid "When using the keyboard shortcut, open the menu at the cursor position"
msgstr ""
"Ao utilizar um atalho de teclado, abra o menu na posição do ponteiro do mouse"

#: prefs.js:178
msgid "Show the delete button on each item"
msgstr "Mostrar o botão apagar em cada item"

#: prefs.js:182
msgid "Tag"
msgstr "Marcador"

#: prefs.js:183
msgid "Show the tag button on each item"
msgstr "Mostrar o botão marcador em cada item"

#: prefs.js:188
msgid "Show the paste button on each item"
msgstr "Mostrar botão colar em cada item"

#: prefs.js:192
msgid "Pin"
msgstr "Fixar"

#: prefs.js:193
msgid "Show the pin/favorite button on each item"
msgstr "Mostrar o botão fixar/favorito em cada item"

#: prefs.js:198
msgid "Show the edit button on each text item"
msgstr "Mostrar o botão editar em cada item de texto"

#: prefs.js:202
msgid "Preview"
msgstr "Pré-visualizar"

#: prefs.js:203
msgid "Show the preview button on each image item"
msgstr "Mostrar o botão pré-visualizar em cada item de imagem"

#: prefs.js:207
msgid "Cache images"
msgstr "Armazenar imagens em cache"

#: prefs.js:208
msgid "Save copied images to clipboard history"
msgstr "Salvar imagens copiadas ao histórico da área de transferência"

#: prefs.js:213
msgid "Excluded Apps"
msgstr "Aplicativos excluídos"

#: prefs.js:214
msgid "Content copied will not be saved while these apps are in focus"
msgstr ""
"Conteúdo copiado não será salvo enquanto esses aplicativos estiverem em foco"

#: prefs.js:225
msgid "Case-sensitive"
msgstr "Case-sensitive"

#: prefs.js:226
msgid "Match uppercase and lowercase letters exactly when searching"
msgstr "Buscar respeitando caracteres maiúsculos e minúsculos"

#: prefs.js:230
msgid "Regular expressions"
msgstr "Expressões regulares"

#: prefs.js:231
msgid "Allow regular expressions to filter clipboard entries"
msgstr ""
"Permitir expressões regulares para filtrar registros da área de transferência"

#: prefs.js:244
msgid "Clear clipboard history on interval"
msgstr "Limpar histórico da área de transferência baseado em tempo"

#: prefs.js:245
msgid "Automatically clear clipboard history at a recurring interval"
msgstr ""
"Limpar automaticamente o histórico da área de transferência em um intervalo "
"de tempo recorrente"

#: prefs.js:249
msgid "History clear interval (in minutes)"
msgstr "Intervalo de limpeza do histórico (em minutos)"

#: prefs.js:269
msgid "Item Actions"
msgstr "Ações dos itens"

#: prefs.js:361
msgid "Icon"
msgstr "Ícone"

#: prefs.js:362
msgid "Clipboard Content"
msgstr "Conteúdo da área de transferência"

#: prefs.js:363
msgid "Both"
msgstr "Ambos"

#: prefs.js:364
msgid "Neither"
msgstr "Nenhum"

#: prefs.js:375
msgid "Toggle the menu"
msgstr "Abrir menu"

#: prefs.js:377
msgid "Previous entry"
msgstr "Entrada anterior"

#: prefs.js:378
msgid "Next entry"
msgstr "Próxima entrada"

#: prefs.js:383
msgid "Enable shortcuts"
msgstr "Habilitar atalhos"

#: prefs.js:408
msgid "Disabled"
msgstr "Desativado"

#: prefs.js:417
msgid "Enter shortcut"
msgstr "Entrar atalho"

#: prefs.js:504
msgid "Window class name, e.g. \"KeePassXC\""
msgstr "Nome da classe da janela, por exemplo, \"KeePassXC\""

#: prefs.js:516
msgid "Choose from installed applications"
msgstr "Escolha de aplicações instaladas"

#: prefs.js:533
msgid "Search applications..."
msgstr "Buscar aplicações..."

