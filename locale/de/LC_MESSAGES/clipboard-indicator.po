#: extension.js:144
msgid "Text will be here"
msgstr "Text wird hier angezeigt"

#: extension.js:240
msgid "Type here to search..."
msgstr "Text eingeben, um zu suchen…"

#: extension.js:315 prefs.js:367
msgid "Private mode"
msgstr "Privater Modus"

#: extension.js:329 prefs.js:369
msgid "Clear history"
msgstr "Verlauf löschen"

#: extension.js:354
msgid "Reset Timer"
msgstr "Timer zurücksetzen"

#: extension.js:375
msgid "Settings"
msgstr "Einstellungen"

#: extension.js:397
msgid "Clipboard is empty"
msgstr "Zwischenablage ist leer"

#: extension.js:696
msgid "Preview Image"
msgstr "Vorschaubild"

#: extension.js:714 prefs.js:192
msgid "Edit"
msgstr "Bearbeiten"

#: extension.js:752 prefs.js:182
msgid "Paste"
msgstr "Einfügen"

#: extension.js:831
msgid "Clear all?"
msgstr "Alles löschen?"

#: extension.js:832
msgid "Are you sure you want to delete all clipboard items?"
msgstr "Soll die Zwischenablage wirklich geleert werden?"

#: extension.js:833
msgid "This operation cannot be undone."
msgstr "Diese Aktion kann nicht rückgängig gemacht werden."

#: extension.js:835
msgid "Clear"
msgstr "Löschen"

#: extension.js:835 extension.js:1015
msgid "Cancel"
msgstr "Abbrechen"

#: extension.js:851
msgid "Clipboard history cleared automatically"
msgstr "Verlauf der Zwischenablage automatisch gelöscht"

#: extension.js:852
msgid "Clipboard history cleared"
msgstr "Verlauf der Zwischenablage gelöscht"

#: extension.js:1014
msgid "Copied to clipboard"
msgstr "In Zwischenablage kopiert"

#: extension.js:1730
msgid "Enter tag…"
msgstr "Schlagwort eingeben…"

#: extension.js:1739 extension.js:1831
msgid "Discard"
msgstr "Verwerfen"

#: extension.js:1748 extension.js:1840
msgid "Save"
msgstr "Speichern"

#: prefs.js:15 prefs.js:256
msgid "UI"
msgstr "Oberfläche"

#: prefs.js:16 prefs.js:257
msgid "Behavior"
msgstr "Verhalten"

#: prefs.js:17 prefs.js:263
msgid "Search"
msgstr "Suche"

#: prefs.js:18 prefs.js:259
msgid "Limits"
msgstr "Grenzwerte"

#: prefs.js:19 prefs.js:258
msgid "Exclusion"
msgstr "Ausnahmen"

#: prefs.js:20 prefs.js:260
msgid "Topbar"
msgstr "Obere Leiste"

#: prefs.js:21 prefs.js:261
msgid "Notifications"
msgstr "Benachrichtigungen"

#: prefs.js:22 prefs.js:262
msgid "Shortcuts"
msgstr "Tastenkombinationen"

#: prefs.js:40
msgid "History Size"
msgstr "Größe des Verlaufs"

#: prefs.js:41
msgid "Maximum number of entries to keep in clipboard history"
msgstr "Maximale Anzahl von Einträgen, die im Verlauf verbleiben"

#: prefs.js:50
msgid "Preview Size (characters)"
msgstr "Vorschaugröße (Zeichen)"

#: prefs.js:51
msgid "Number of characters shown per entry in the history menu"
msgstr "Anzahl von Zeichen, die pro Eintrag im Verlauf angezeigt werden"

#: prefs.js:60
msgid "Max cache file size (MB)"
msgstr "Maximale Größe der Cachedatei (MB)"

#: prefs.js:61
msgid "Maximum disk space used for caching clipboard data"
msgstr ""
"Maximaler Speicherplatz, der zum Zwischenspeichern von Zwischenablagedaten "
"verwendet wird"

#: prefs.js:70
msgid "Number of characters in top bar"
msgstr "Anzahl der Zeichen in oberer Leiste"

#: prefs.js:71
msgid "Length of the clipboard content preview shown in the panel"
msgstr ""
"Vorschaulänge des aktuellen Inhalts der Zwischenablage in der oberen Leiste"

#: prefs.js:80
msgid "What to show in top bar"
msgstr "Folgendes in oberer Leiste anzeigen"

#: prefs.js:85
msgid "Remove down arrow in top bar"
msgstr "Pfeil in oberer Leiste ausblenden"

#: prefs.js:86
msgid "Hide the dropdown arrow next to the clipboard indicator"
msgstr "Den Pfeil neben dem Symbol der Erweiterung ausblenden"

#: prefs.js:90
msgid "Blink icon on copy"
msgstr "Symbol beim Kopieren aufleuchten lassen"

#: prefs.js:91
msgid "Briefly flash the indicator icon when something is copied"
msgstr ""
"Symbol in oberer Leiste kurz aufleuchten lassen, wenn Inhalte kopiert werden"

#: prefs.js:95
msgid "Cache only pinned items"
msgstr "Nur Favoriten im Cache behalten"

#: prefs.js:96
msgid "Only save pinned (favorite) entries to disk"
msgstr "Nur angeheftete Einträge (Favoriten) zwischenspeichern"

#: prefs.js:100
msgid "Show notification on copy"
msgstr "Benachrichtigung beim Kopieren anzeigen"

#: prefs.js:101
msgid "Display a notification each time text is copied"
msgstr "Bei jedem Kopiervorgang eine Benachrichtigung anzeigen"

#: prefs.js:105
msgid "Show notification on cycle"
msgstr "Benachrichtigung beim Durchschalten anzeigen"

#: prefs.js:106
msgid "Display a notification when cycling through entries with shortcuts"
msgstr ""
"Eine Benachrichtigung anzeigen, wenn per Tastenkombination zwischen "
"Einträgen gewechselt wird"

#: prefs.js:110
msgid "Show notification on Clear History"
msgstr "Benachrichtigung beim Löschen des Verlaufs anzeigen"

#: prefs.js:111
msgid "Display a notification when clipboard history is cleared"
msgstr "Eine Benachrichtigung anzeigen, wenn der Verlauf gelöscht wird"

#: prefs.js:115
msgid "Prompt for confirmation on Clear History"
msgstr "Bestätigung beim Löschen des Verlaufs anzeigen"

#: prefs.js:116
msgid "Ask before deleting all clipboard entries"
msgstr "Nachfragen, bevor alle Einträge gelöscht werden"

#: prefs.js:120
msgid "Remove whitespace around text"
msgstr "Leerzeichen vor und nach dem Text entfernen"

#: prefs.js:121
msgid "Strip leading and trailing whitespace from text entries on copy"
msgstr "Beim Kopieren Leerzeichen vor und nach dem Text entfernen"

#: prefs.js:125
msgid "Move item to the top after selection"
msgstr "Eintrag bei Auswahl nach oben verschieben"

#: prefs.js:126
msgid "When selecting an entry, bring it to the top of the history"
msgstr "Eintrag bei Auswahl an den Anfang der Verlaufsliste verschieben"

#: prefs.js:130
msgid "Keep selected entry after Clear History"
msgstr "Aktiven Eintrag beim Löschen des Verlaufs beibehalten"

#: prefs.js:131
msgid ""
"The currently active clipboard entry will not be removed when clearing "
"history"
msgstr ""
"Den derzeit ausgewählten Eintrag nicht löschen, wenn der Verlauf gelöscht "
"wird"

#: prefs.js:135
msgid "Place the pinned section on the bottom"
msgstr "Favoriten am Ende der Liste anzeigen"

#: prefs.js:136
msgid "Move the pinned section to the bottom of the menu. Requires re-login"
msgstr ""
"Den Bereich mit angehefteten Einträgen ans Ende der Liste verschieben "
"(erfordert Neuanmeldung)"

#: prefs.js:140
msgid "Show Search Bar"
msgstr "Suchleiste anzeigen"

#: prefs.js:141
msgid "Display a search field at the top of the clipboard menu"
msgstr "Ein Suchfeld oben im Menü anzeigen"

#: prefs.js:144
msgid "Show Private Mode"
msgstr "Schaltfläche „Privater Modus“ anzeigen"

#: prefs.js:145
msgid "Display the private mode toggle in the clipboard menu"
msgstr "Den Schalter zum Aktivieren des privaten Modus' im Menü anzeigen"

#: prefs.js:148
msgid "Show Settings Button"
msgstr "Schaltfläche „Einstellungen“ anzeigen"

#: prefs.js:149
msgid "Display a shortcut to these settings in the clipboard menu"
msgstr ""
"Die Schaltfläche für den schnellen Zugriff auf diese Einstellungen im Menü "
"anzeigen"

#: prefs.js:152
msgid "Show Clear History Button"
msgstr "Schaltfläche „Verlauf löschen“ anzeigen"

#: prefs.js:153
msgid "Display the clear history button in the clipboard menu"
msgstr "Die Schaltfläche zum Löschen des Verlaufs im Menü anzeigen"

#: prefs.js:157
msgid "Clear clipboard history on system reboot"
msgstr "Verlauf bei Neustart löschen"

#: prefs.js:158
msgid "Delete all cached clipboard entries when the system starts"
msgstr ""
"Alle zwischengespeicherten Einträge im Verlauf beim Neustart des Systems "
"löschen"

#: prefs.js:162
msgid "Paste on select"
msgstr "Bei Auswahl einfügen"

#: prefs.js:163
msgid "Automatically paste the entry into the active window when selected"
msgstr ""
"Den jeweiligen Eintrag automatisch im aktiven Fenster einfügen, wenn dieser "
"ausgewählt wird"

#: prefs.js:167
msgid "Open menu at cursor"
msgstr "Menü an Zeigerposition öffnen"

#: prefs.js:168
msgid "When using the keyboard shortcut, open the menu at the cursor position"
msgstr ""
"Bei Nutzung der Tastenkombination das Menü an der aktuellen Position des "
"Mauszeigers öffnen"

#: prefs.js:172
msgid "Delete"
msgstr "Löschen"

#: prefs.js:173
msgid "Show the delete button on each item"
msgstr "Die Schaltfläche zum Löschen an jedem Eintrag anzeigen"

#: prefs.js:177
msgid "Tag"
msgstr "Schlagwort hinzufügen"

#: prefs.js:178
msgid "Show the tag button on each item"
msgstr ""
"Die Schaltfläche zum Hinzufügen eines Schlagwortes an jedem Eintrag anzeigen"

#: prefs.js:183
msgid "Show the paste button on each item"
msgstr "Die Schaltfläche zum Einfügen an jedem Eintrag anzeigen"

#: prefs.js:187
msgid "Pin"
msgstr "Anheften"

#: prefs.js:188
msgid "Show the pin/favorite button on each item"
msgstr "Die Schaltfläche zum Anheften an jedem Eintrag anzeigen"

#: prefs.js:193
msgid "Show the edit button on each text item"
msgstr "Die Schaltfläche zum Bearbeiten an jedem Texteintrag anzeigen"

#: prefs.js:197
msgid "Preview"
msgstr "Vorschau"

#: prefs.js:198
msgid "Show the preview button on each image item"
msgstr "Die Schaltfläche für die Vorschau an jedem Bildeintrag anzeigen"

#: prefs.js:202
msgid "Cache images"
msgstr "Bilder zwischenspeichern"

#: prefs.js:203
msgid "Save copied images to clipboard history"
msgstr "Kopierte Bilder in Verlauf aufnehmen"

#: prefs.js:208
msgid "Excluded Apps"
msgstr "Ausgeschlossene Anwendungen"

#: prefs.js:209
msgid "Content copied will not be saved while these apps are in focus"
msgstr ""
"Kopierte Inhalte werden nicht gespeichert, während diese Anwendungen "
"fokussiert sind"

#: prefs.js:220
msgid "Case-sensitive"
msgstr "Groß- und Kleinschreibung beachten"

#: prefs.js:221
msgid "Match uppercase and lowercase letters exactly when searching"
msgstr "Bei der Suche Groß- und Kleinbuchstaben exakt prüfen"

#: prefs.js:225
msgid "Regular expressions"
msgstr "Reguläre Ausdrücke"

#: prefs.js:226
msgid "Allow regular expressions to filter clipboard entries"
msgstr ""
"Verwendung von regulären Ausdrücken beim Filtern von Einträgen zulassen"

#: prefs.js:239
msgid "Clear clipboard history on interval"
msgstr "Verlauf nach einiger Zeit löschen"

#: prefs.js:240
msgid "Automatically clear clipboard history at a recurring interval"
msgstr "Verlauf nach einem wiederkehrenden Zeitintervall automatisch löschen"

#: prefs.js:244
msgid "History clear interval (in minutes)"
msgstr "Löschintervall (in Minuten)"

#: prefs.js:264
msgid "Item Actions"
msgstr "Aktionen je Eintrag"

#: prefs.js:354
msgid "Icon"
msgstr "Symbol"

#: prefs.js:355
msgid "Clipboard Content"
msgstr "Inhalt der Zwischenablage"

#: prefs.js:356
msgid "Both"
msgstr "Beides"

#: prefs.js:357
msgid "Neither"
msgstr "Nichts"

#: prefs.js:368
msgid "Toggle the menu"
msgstr "Menü öffnen/schließen"

#: prefs.js:370
msgid "Previous entry"
msgstr "Vorheriger Eintrag"

#: prefs.js:371
msgid "Next entry"
msgstr "Nächster Eintrag"

#: prefs.js:376
msgid "Enable shortcuts"
msgstr "Tastenkombinationen aktivieren"

#: prefs.js:401
msgid "Disabled"
msgstr "Deaktiviert"

#: prefs.js:410
msgid "Enter shortcut"
msgstr "Tastenkombination eingeben"

#: prefs.js:497
msgid "Window class name, e.g. \"KeePassXC\""
msgstr "Name der Fensterklasse, z. B. \"KeePassXC\""

#: prefs.js:509
msgid "Choose from installed applications"
msgstr "Installierte Anwendung auswählen"

#: prefs.js:526
msgid "Search applications..."
msgstr "Anwendungen suchen..."

#~ msgid "Adds a paste button to each entry that lets you paste it directly"
#~ msgstr "Fügt jedem Eintrag eine Schaltfläche zum direkten Einfügen hinzu"

#~ msgid "Requires restarting the extension"
#~ msgstr "Erfordert Neustart der Erweiterung"
