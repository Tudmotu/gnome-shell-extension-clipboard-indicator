#: extension.js:113
msgid "Text will be here"
msgstr "Текст будет здесь"

#: extension.js:187
msgid "Type here to search..."
msgstr "Введите текст для поиска..."

#: extension.js:256 prefs.js:257
msgid "Private mode"
msgstr "Приватный режим"

#: extension.js:270 prefs.js:259
msgid "Clear history"
msgstr "Очистить историю"

#: extension.js:315
msgid "Settings"
msgstr "Настройки"

#: extension.js:338
msgid "Clipboard is empty"
