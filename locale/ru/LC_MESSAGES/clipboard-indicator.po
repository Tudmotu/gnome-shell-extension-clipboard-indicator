msgid "Max cache file size (MB)"
msgstr "Максимальный размер файла кэша (МБ)"

#: prefs.js:58
msgid "Number of characters in top bar"
msgstr "Количество символов в верхней панели"

#: prefs.js:67
msgid "What to show in top bar"
msgstr "Что показывать в верхней панели"

#: prefs.js:72
msgid "Remove down arrow in top bar"
msgstr "Убрать стрелку вниз в верхней панели"

#: prefs.js:76
