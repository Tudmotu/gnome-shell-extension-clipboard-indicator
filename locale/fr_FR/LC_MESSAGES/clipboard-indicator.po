msgstr "Raccourcis"

#: prefs.js:40
msgid "History Size"
msgstr "Taille de l'historique"

#: prefs.js:41
msgid "Maximum number of entries to keep in clipboard history"
msgstr "Nombre maximum d'entrées à conserver dans l'historique"

#: prefs.js:50
msgid "Preview Size (characters)"
msgstr "Taille de l'aperçu (nombre de caractères)"

#: prefs.js:51
msgid "Number of characters shown per entry in the history menu"
msgstr "Nombre de caractères affichés par entrée dans le menu"

#: prefs.js:60
msgid "Max cache file size (MB)"
msgstr "Taille maximale du fichier cache (MB)"

#: prefs.js:61
msgid "Maximum disk space used for caching clipboard data"
msgstr "Espace disque maximal utilisé pour mettre en cache les données"

#: prefs.js:70
msgid "Number of characters in top bar"
msgstr "Nombre de caractères dans le panneau"

#: prefs.js:71
msgid "Length of the clipboard content preview shown in the panel"
msgstr "Longueur de l'aperçu du contenu affiché dans le panneau"

#: prefs.js:80
msgid "What to show in top bar"
msgstr "Afficher dans le panneau"

#: prefs.js:85
msgid "Remove down arrow in top bar"
msgstr "Retirer la flèche vers le bas du panneau"

#: prefs.js:86
msgid "Hide the dropdown arrow next to the clipboard indicator"
msgstr "Masquer la flèche à côté de l'indicateur du presse-papiers"

#: prefs.js:90
msgid "Blink icon on copy"
msgstr "Faire clignoter l'icône lors de la copie"

#: prefs.js:91
msgid "Briefly flash the indicator icon when something is copied"
msgstr "Faire clignoter brièvement l'icône lors d'une copie"

#: prefs.js:95
msgid "Cache only pinned items"
msgstr "Mettre en cache seulement les éléments favoris"

#: prefs.js:96
msgid "Only save pinned (favorite) entries to disk"
msgstr "N'enregistrer sur le disque que les entrées épinglées (favoris)"

#: prefs.js:100
msgid "Show notification on copy"
msgstr "Afficher une notification lors de la copie"

#: prefs.js:101
msgid "Display a notification each time text is copied"
msgstr "Afficher une notification à chaque fois qu'un texte est copié"

#: prefs.js:105
msgid "Show notification on cycle"
msgstr "Afficher une notification lors du défilement de l’historique"

#: prefs.js:106
msgid "Display a notification when cycling through entries with shortcuts"
msgstr "Afficher une notification lors du défilement via les raccourcis"

#: prefs.js:110
msgid "Show notification on Clear History"
msgstr "Afficher une notification lors de l'effacement de l'historique"

#: prefs.js:111
msgid "Display a notification when clipboard history is cleared"
msgstr "Afficher une notification quand l'historique est effacé"

#: prefs.js:115
msgid "Prompt for confirmation on Clear History"
msgstr "Confirmer l'effacement de l'historique"

#: prefs.js:116
msgid "Ask before deleting all clipboard entries"
msgstr "Demander avant de supprimer toutes les entrées"

#: prefs.js:120
msgid "Remove whitespace around text"
msgstr "Supprimer les espaces autour du texte"

#: prefs.js:121
msgid "Strip leading and trailing whitespace from text entries on copy"
msgstr "Supprimer les espaces au début et à la fin lors de la copie"

#: prefs.js:125
msgid "Move item to the top after selection"
msgstr "Déplacer l'élément vers le haut après la sélection"

#: prefs.js:126
msgid "When selecting an entry, bring it to the top of the history"
msgstr "Placer l'élément sélectionné en haut de l'historique"

#: prefs.js:130
msgid "Keep selected entry after Clear History"
msgstr "Conserver l'entrée sélectionnée après l'effacement de l'historique"

#: prefs.js:131
msgid ""
"The currently active clipboard entry will not be removed when clearing "
"history"
msgstr ""
"L'entrée actuellement active ne sera pas supprimée lors de l'effacement de "
"l'historique"

#: prefs.js:135
msgid "Place the pinned section on the bottom"
msgstr "Placer la section épinglée en bas"

#: prefs.js:136
msgid "Move the pinned section to the bottom of the menu. Requires re-login"
msgstr "Placer la section épinglée en bas (nécessite de se reconnecter)"

#: prefs.js:140
msgid "Show Search Bar"
msgstr "Afficher la barre de recherche"

#: prefs.js:141
msgid "Display a search field at the top of the clipboard menu"
msgstr "Afficher un champ de recherche en haut du menu"

#: prefs.js:144
msgid "Show Private Mode"
msgstr "Afficher le mode privé"

#: prefs.js:145
msgid "Display the private mode toggle in the clipboard menu"
msgstr "Afficher l'interrupteur du mode privé dans le menu"

#: prefs.js:148
msgid "Show Settings Button"
msgstr "Afficher le bouton paramètres"

#: prefs.js:149
msgid "Display a shortcut to these settings in the clipboard menu"
msgstr "Afficher un raccourci vers ces paramètres dans le menu"

#: prefs.js:152
msgid "Show Clear History Button"
msgstr "Afficher le bouton d'effacement"

#: prefs.js:153
msgid "Display the clear history button in the clipboard menu"
msgstr "Afficher le bouton d'effacement de l'historique dans le menu"

#: prefs.js:157
msgid "Clear clipboard history on system reboot"
msgstr "Effacer l'historique du presse-papiers au redémarrage du système"

#: prefs.js:158
msgid "Delete all cached clipboard entries when the system starts"
msgstr "Supprimer toutes les entrées en cache au démarrage du système"

#: prefs.js:162
msgid "Paste on select"
msgstr "Coller sur la sélection"

#: prefs.js:163
msgid "Automatically paste the entry into the active window when selected"
msgstr "Coller automatiquement l'entrée dans la fenêtre active après sélection"

#: prefs.js:167
msgid "Open menu at cursor"
msgstr "Ouvrir le menu au curseur"

#: prefs.js:168
msgid "When using the keyboard shortcut, open the menu at the cursor position"
msgstr ""
"Ouvrir le menu à la position du curseur lors de l'utilisation du raccourci"

#: prefs.js:172
msgid "Delete"
msgstr "Supprimer"

#: prefs.js:173
msgid "Show the delete button on each item"
msgstr "Afficher le bouton supprimer sur chaque élément"

#: prefs.js:177
msgid "Tag"
msgstr "Étiqueter"

#: prefs.js:178
msgid "Show the tag button on each item"
msgstr "Afficher le bouton d'étiquette sur chaque élément"

#: prefs.js:183
msgid "Show the paste button on each item"
msgstr "Afficher le bouton coller sur chaque élément"

#: prefs.js:187
msgid "Pin"
msgstr "Épingler"

#: prefs.js:188
msgid "Show the pin/favorite button on each item"
msgstr "Afficher le bouton de favori sur chaque élément"

#: prefs.js:193
msgid "Show the edit button on each text item"
msgstr "Afficher le bouton de modification sur chaque élément de texte"

#: prefs.js:197
msgid "Preview"
msgstr "Aperçu"

#: prefs.js:198
msgid "Show the preview button on each image item"
msgstr "Afficher le bouton d'aperçu sur chaque image"

#: prefs.js:202
msgid "Cache images"
msgstr "Enregistrer les images dans l’historique"

#: prefs.js:203
msgid "Save copied images to clipboard history"
msgstr "Sauvegarder les images copiées dans l'historique"

#: prefs.js:208
msgid "Excluded Apps"
msgstr "Applications exclues"

#: prefs.js:209
msgid "Content copied will not be saved while these apps are in focus"
msgstr ""
"Le contenu copié ne sera pas enregistré tant que ces applications sont "
"actives"

#: prefs.js:220
msgid "Case-sensitive"
msgstr "Sensible à la casse"

#: prefs.js:221
msgid "Match uppercase and lowercase letters exactly when searching"
msgstr "Respecter la casse lors de la recherche"

#: prefs.js:225
msgid "Regular expressions"
msgstr "Expressions régulières"

#: prefs.js:226
msgid "Allow regular expressions to filter clipboard entries"
msgstr "Autoriser les expressions régulières pour filtrer l'historique"

#: prefs.js:239
msgid "Clear clipboard history on interval"
msgstr "Effacer l'historique du presse-papiers à intervalles réguliers"

#: prefs.js:240
msgid "Automatically clear clipboard history at a recurring interval"
msgstr "Effacer l'historique du presse-papiers à intervalles réguliers"

#: prefs.js:244
msgid "History clear interval (in minutes)"
msgstr "Intervalle d'effacement de l'historique (en minutes)"

#: prefs.js:264
msgid "Item Actions"
msgstr "Actions de l'élément"

#: prefs.js:354
msgid "Icon"
msgstr "Icône"

#: prefs.js:355
msgid "Clipboard Content"
msgstr "Contenu"

#: prefs.js:356
msgid "Both"
msgstr "Les deux"

#: prefs.js:357
msgid "Neither"
msgstr "Aucun"

#: prefs.js:368
msgid "Toggle the menu"
msgstr "Afficher/cacher le menu"

#: prefs.js:370
msgid "Previous entry"
msgstr "Entrée précédente"

#: prefs.js:371
msgid "Next entry"
msgstr "Entrée suivante"

#: prefs.js:376
msgid "Enable shortcuts"
msgstr "Activer les raccourcis"

#: prefs.js:401
msgid "Disabled"
msgstr "Désactivé"

#: prefs.js:410
msgid "Enter shortcut"
msgstr "Entrer un raccourci"

#: prefs.js:497
msgid "Window class name, e.g. \"KeePassXC\""
msgstr "Classe de fenêtre (ex. : « KeePassXC »)"

#: prefs.js:509
msgid "Choose from installed applications"
msgstr "Choisir parmi les applications installées"

#: prefs.js:526
msgid "Search applications..."
